# App
APP_NAME=nvai
DEBUG=true

# 对外鉴权 key — 客户端请求时携带
API_KEY=change-me

# 管理后台鉴权 key — 登录 admin 面板用
ADMIN_KEY=change-me-admin

# 上游 NVIDIA API
UPSTREAM_BASE_URL=https://integrate.api.nvidia.com
KEYS_FILE=keys.json

# 可选 HTTP 代理
# HTTP_PROXY=http://127.0.0.1:7890

# 故障转移
MAX_RETRIES=3
KEY_COOLDOWN_SECONDS=60
KEY_MAX_CONSECUTIVE_FAILURES=3

# 上游超时 (秒)
UPSTREAM_TIMEOUT=120

# CORS
CORS_ORIGINS=["*"]
